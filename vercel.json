{
  "buildCommand": "cd frontend && npm install --registry=https://registry.npmmirror.com && npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/v1/ai/:path*", "destination": "/api/_ai?_route=:path*" },
    { "source": "/api/ai/:path*", "destination": "/api/_ai?_route=:path*" },
    { "source": "/health", "destination": "/api/health" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
