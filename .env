# AI智师导学系统 - 环境变量配置
# 注意：.env 文件包含敏感信息，不要提交到版本控制

# Agnes AI API配置
AGNES_API_KEY=wk-FCVfNuNNGxEHtGkkG4Ttsmp39iHDFrndIauVJmTq0QcgGqyc
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
DEFAULT_MODEL=agnes-2.0-flash

# 服务端口
PORT=8000

# CORS允许的来源（多个用逗号分隔，开发环境可用 *）
ALLOWED_ORIGINS=*

# JWT密钥（生产环境请更改为随机长字符串）
JWT_SECRET=ai-tutor-jwt-secret-2024-very-long-and-secure

# SQLite数据库路径（默认为 data/users.db）
TUTOR_DB_PATH=data/users.db
